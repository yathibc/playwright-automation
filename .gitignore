#.gitignore for the root of the Playwright project.
# Exclude OS junk and editor metadata.
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

/.idea/
/.vscode/

# Log files
*.log
logs/

# Node artifacts
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build and dependency outputs
/target/
*.class
generated-sources/
generated-test-sources/

# Playwright and automation specific
Playwright_TS/node_modules/
Playwright_TS/target/
Playwright_TS/target/classes/
Playwright_TS/target/test-classes/
Playwright_TS/screenshots/
Playwright_TS/sessions/
Playwright_TS/logs/
screenshots/
playwright_java_tickets/

# General temporary files
*.tmp
*.temp
tmp/
*.swp
*.swo
*.pid
*.seed

# Secrets and env configs
.env
*.env
accounts*.json
*.key
*.pem